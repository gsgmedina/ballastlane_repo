{
  "info": {
    "name": "Task Manager API",
    "_postman_id": "b1a7f0e2-1c3d-4a6b-9e2f-task-manager-bla",
    "description": "Collection for the BLA .NET technical exercise Task Manager API.\n\n## How to use\n1. Run the API: `dotnet run --project src/TaskManager.Api` (works with either the SQLite or Cosmos provider).\n2. Adjust the `baseUrl` collection variable if your ports differ (HTTPS `https://localhost:7179`, HTTP `http://localhost:5195`).\n3. Run **Auth → Login (demo)** first — it stores the JWT in the `accessToken` variable that the Tasks requests use automatically.\n4. Or just hit **Run collection**: the requests are ordered (login → create → get → update → delete) and chain via variables.\n\n## Notes\n- The API uses a dev HTTPS certificate. If Postman blocks it, turn **Settings → General → SSL certificate verification** OFF, or set `baseUrl` to the HTTP endpoint.\n- Seeded demo account: `demo@taskmanager.local` / `Demo123!`.\n- Collection-level auth is Bearer `{{accessToken}}`; anonymous endpoints (ping/register/login) override this with No Auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:7179", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "demoEmail", "value": "demo@taskmanager.local", "type": "string" },
    { "key": "demoPassword", "value": "Demo123!", "type": "string" },
    { "key": "createdEmail", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Ping (public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/ping",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "ping"]
            },
            "description": "Anonymous health/demo endpoint (non-authorized)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('reports ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (new user)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{$randomEmail}}\",\n  \"password\": \"Password1\",\n  \"displayName\": \"Postman User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Creates a new user (random email) and returns a JWT. Stores the token + email for reuse."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('returns a token', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('accessToken', body.token);",
                  "pm.collectionVariables.set('createdEmail', body.user.email);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (demo)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticates the seeded demo user and stores the JWT in {{accessToken}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns a token', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('accessToken', body.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Me (authorized)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Returns the current user's profile. Requires the Bearer token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('has an email', () => pm.expect(pm.response.json().email).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get all tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Lists the current user's tasks."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Task from Postman\",\n  \"description\": \"Created via the Postman collection\",\n  \"dueDateUtc\": \"2026-12-31T00:00:00Z\",\n  \"status\": \"Todo\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Creates a task and stores its id in {{taskId}} for the requests below."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('defaults are correct', () => pm.expect(body.status).to.eql('Todo'));",
                  "pm.collectionVariables.set('taskId', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get task by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Fetches the task created above."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('id matches', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('taskId')));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Task from Postman (updated)\",\n  \"description\": \"Now in progress\",\n  \"dueDateUtc\": \"2026-12-31T00:00:00Z\",\n  \"status\": \"InProgress\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Full update of the task."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status updated', () => pm.expect(pm.response.json().status).to.eql('InProgress'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Deletes the task."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('204 No Content', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Negative tests",
      "item": [
        {
          "name": "Tasks without token -> 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Protected endpoint without a token must return 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login wrong password -> 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"WrongPassword1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Invalid credentials must return 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create invalid task -> 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"description\": null,\n  \"dueDateUtc\": \"2000-01-01T00:00:00Z\",\n  \"status\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Empty title + past due date must return 400 with a per-field error map. Requires a valid token (run Login first)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('has validation errors', () => pm.expect(pm.response.json().errors).to.be.an('object'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
