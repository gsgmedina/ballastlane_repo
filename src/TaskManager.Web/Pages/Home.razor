@page "/"
@inject NavigationManager Navigation

<PageTitle>Task Manager</PageTitle>

<AuthorizeView>
    <Authorized>
        @{ Navigation.NavigateTo("tasks", replace: true); }
    </Authorized>
    <NotAuthorized>
        <div class="text-center py-5">
            <h1 class="display-6 mb-3">✓ Task Manager</h1>
            <p class="lead text-muted mb-4">
                A small, secure task tracker — create, organize and complete your tasks.
            </p>
            <a class="btn btn-primary btn-lg me-2" href="login">Sign in</a>
            <a class="btn btn-outline-primary btn-lg" href="register">Create account</a>
        </div>
    </NotAuthorized>
</AuthorizeView>
